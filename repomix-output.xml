                            &:active img {
                                @apply scale-95;
                            }
            
                            p {
                                @apply text-sm text-center font-medium w-40 text-gray-800 dark:text-gray-200 relative z-10 transition-colors duration-300 max-md:text-left max-md:w-full max-md:text-[17px] max-md:text-black dark:max-md:text-white max-md:font-normal;
