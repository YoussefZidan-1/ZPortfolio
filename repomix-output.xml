        @apply w-fit h-fit absolute top-16 left-7/12 bg-white/30 dark:bg-black/40 backdrop-blur-xl shadow-2xl drop-shadow-2xl rounded-xl overflow-hidden max-md:inset-0 max-md:w-full max-md:h-full max-md:rounded-none max-md:bg-white dark:max-md:bg-black;
