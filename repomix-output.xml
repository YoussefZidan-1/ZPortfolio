    --terminal-accent: #00a154;
    --breakpoint-3xl: 1920px;
}

.scrollbar-hide::-webkit-scrollbar {
    display: none;
}
.scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
}

input::selection {
    background: rgba(236, 72, 153, 0.3);
}

@utility flex-center {
