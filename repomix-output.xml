@import "tailwindcss";

@theme {
    --font-georama: "Georama", sans-serif;
    --font-terminal: "JetBrainsMonoNF", "Roboto Mono", monospace;
    --terminal-bg: #0f1720;
    --terminal-foreground: #cbd5e1;
    --terminal-accent: #00a154;
    --breakpoint-3xl: 1920px;
}

@utility flex-center {
    @apply flex items-center justify-center;
}

@utility col-center {
    @apply flex flex-col items-center justify-center;
}

@utility abs-center {
    @apply absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2;
}

@layer base {
    html, body {
        @apply w-full max-w-[100vw] h-[100dvh] overflow-hidden fixed top-0 left-0 bg-[url('/images/wallpaper.webp')] bg-cover bg-no-repeat bg-center max-md:bg-[url('/images/wallpaper-2.webp')];
    }

    main {
        @apply fixed inset-0 w-full h-full overflow-hidden w-dvw h-dvh;
    }

    nav {
        @apply flex justify-between items-center bg-white/30 backdrop-blur-xl p-2 px-5 select-none;
        div {
            @apply flex items-center max-sm:w-full max-sm:justify-center gap-5;
            &:last-child {
                @apply max-sm:hidden;
            }
        }
        ul {
            @apply flex items-center gap-5 max-sm:hidden;
            p {
                @apply p-1 rounded text-sm cursor-pointer hover:bg-blue-200 hover:text-blue-900 transition-all;
            }
        }
        time {
            @apply text-sm font-medium text-black;
        }
    }
}

@layer components {
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    input::selection {
        background: rgba(236, 72, 153, 0.3);
    }

    .icon {
        @apply p-1 hover:bg-gray-200 rounded hover:cursor-default;
    }

    #welcome {
        @apply text-gray-200 flex flex-col justify-center items-center absolute top-[60vh] md:top-1/2 left-1/2 -translate-x-1/2 md:-translate-y-1/2 select-none w-full px-5 max-md:hidden;
    }

    #dock {
        @apply absolute bottom-5 left-1/2 -translate-x-1/2 z-50 select-none max-md:hidden;
        .dock-container {
            @apply bg-white/20 backdrop-blur-2xl border border-white/20 justify-between rounded-3xl p-2.5 flex items-end gap-2;
        }
        .tooltip {
            @apply !py-1 !px-3 !w-fit !text-center !text-xs !rounded-md !bg-blue-200 !text-blue-900 !shadow-2xl;
        }
        .dock-icon {
            @apply size-14 3xl:size-20 cursor-pointer;
            img {
                @apply object-cover object-center;
            }
        }
    }

    #window-controls {
        @apply flex gap-2 max-md:absolute max-md:left-4 max-md:bottom-2.5 max-md:gap-0;
        .close {
            @apply size-3.5 rounded-full bg-[#ff6157] cursor-pointer max-md:w-auto max-md:h-auto max-md:bg-transparent max-md:flex max-md:items-center max-md:justify-center max-md:rounded-none max-md:text-blue-600 max-md:font-medium max-md:p-2 max-md:-ml-2;
            svg {
                @apply max-md:stroke-blue-600 max-md:w-6 max-md:h-6 max-md:rotate-90;
            }
        }
        .minimize {
            @apply size-3.5 rounded-full bg-[#ffc030] max-md:hidden;
        }
        .maximize {
            @apply size-3.5 rounded-full bg-[#2acb42] max-md:hidden;
        }
    }

    #window-header {
        @apply flex items-center justify-between px-4 py-3 rounded-t-lg bg-white/10 border-b border-white/20 select-none text-sm text-indigo-500 max-md:pt-[56px] max-md:pb-3 max-md:bg-white/95 max-md:backdrop-blur-3xl max-md:border-gray-200/80 max-md:items-center max-md:justify-center max-md:relative max-md:rounded-none;
        h2 {
            @apply max-md:text-center max-md:font-semibold max-md:text-[17px] max-md:text-black max-md:w-full max-md:mx-auto max-md:truncate max-md:px-10;
        }
    }

    /* Window General Mobile Reset */
    .os-window {
        @apply max-md:inset-0 max-md:w-full max-md:h-full max-md:rounded-none max-md:z-[100];
        > div:last-child {
            @apply max-md:h-full max-md:overflow-y-auto max-md:overflow-x-hidden max-md:pb-12;
        }
    }

    #safari {
        @apply w-4xl absolute top-40 left-2/12 bg-white/30 backdrop-blur-xl shadow-2xl drop-shadow-2xl rounded-xl overflow-hidden max-md:inset-0 max-md:w-full max-md:h-full max-md:rounded-none max-md:bg-white;
        .search {
            @apply flex items-center gap-3 w-2/3 bg-white/30 backdrop-blur-xl border border-gray-300 rounded-lg px-3 py-2 max-md:flex-1 max-md:ml-10 max-md:h-10 max-md:bg-[#f2f2f7] max-md:rounded-[10px] max-md:px-3 max-md:justify-center max-md:border-none;
            input {
                @apply placeholder:text-indigo-400 max-md:text-center max-md:text-[17px] max-md:w-full max-md:bg-transparent;
            }
        }
        .blog {
            @apply bg-transparent backdrop-blur-xl p-10 max-w-3xl mx-auto max-md:p-6 max-md:w-full max-md:max-w-full;
            h2 {
                @apply text-xl font-bold text-pink-600 mb-10 max-md:text-2xl max-md:text-black max-md:mb-6;
            }
            .blog-post {
                @apply grid grid-cols-12 space-x-5 max-md:flex max-md:flex-col max-md:gap-3 max-md:mb-8 max-md:ml-0 max-md:space-x-0;
                img {
                    @apply size-full rounded-md object-cover max-md:aspect-video max-md:rounded-xl max-md:w-full;
                }
                .content {
                    @apply col-span-10 space-y-3;
                    p {
                        @apply text-xs text-gray-600;
                    }
                    h3 {
                        @apply font-semibold text-base text-gray-800;
                    }
                    a {
                        @apply text-blue-600 text-xs hover:underline flex items-center gap-3;
                    }
                }
            }
        }
        #window-header {
            @apply max-md:pt-[56px] max-md:px-4 max-md:pb-3;
            > svg, > div:not(.search):not(#window-controls) {
                @apply max-md:hidden;
            }
        }
    }

    #terminal {
        @apply w-xl absolute top-32 left-1/12 bg-black/30 backdrop-blur-xl shadow-2xl drop-shadow-2xl rounded-xl overflow-hidden max-md:inset-0 max-md:w-full max-md:h-full max-md:rounded-none max-md:bg-[#0A0B1A];
        h2 {
            @apply font-bold text-sm text-center w-full max-md:text-white/50;
        }
        #window-header {
            @apply max-md:bg-[#0A0B1A] max-md:border-b max-md:border-white/10;
        }
        #window-controls .close svg {
            @apply max-md:stroke-white;
        }
    }

    #contact {
        @apply max-w-2xl absolute top-60 left-5/12 bg-white/30 backdrop-blur-xl shadow-2xl drop-shadow-2xl rounded-xl overflow-hidden max-md:inset-0 max-md:w-full max-md:h-full max-md:rounded-none max-md:bg-[#f2f2f7];
        h2 {
            @apply font-bold text-sm text-center w-full;
        }
        h3 {
            @apply text-xl font-semibold max-md:text-black;
        }
        .p-5 {
            @apply max-md:py-5 max-md:px-6 max-md:bg-white max-md:m-4 max-md:rounded-2xl max-md:shadow-[0_1px_3px_rgba(0,0,0,0.05)];
        }
        p {
            @apply max-md:text-gray-600;
        }
        ul {
            @apply flex items-center gap-3 max-md:flex-col max-md:items-center max-md:p-0 max-md:mt-6;
            li {
                @apply rounded-lg p-3 w-60 hover:-translate-y-0.5 hover:scale-105 origin-center transition-all duration-300 max-md:w-full max-md:mb-3 max-md:rounded-xl max-md:transform-none max-md:hover:scale-100;
                a {
                    @apply space-y-5;
                }
                p {
                    @apply font-semibold text-sm text-white;
                }
            }
        }
    }

    #photos {
        @apply max-w-3xl absolute top-96 left-1/2 -translate-y-1/2 bg-white/30 backdrop-blur-xl shadow-2xl drop-shadow-2xl rounded-xl overflow-hidden max-md:inset-0 max-md:w-full max-md:h-full max-md:rounded-none max-md:bg-white;
        .sidebar {
            @apply w-3/12 flex-none bg-black/10 border-r border-black/10 flex flex-col p-5 max-md:hidden;
            h2 {
                @apply text-xs font-medium text-black mb-1;
            }
            ul {
                li {
                    @apply flex space-y-1 items-center gap-2 px-3 py-2 rounded-md cursor-pointer transition-colors;
                    &:first-child {
                        @apply bg-blue-100 text-blue-700;
                    }
                    img {
                        @apply w-4;
                    }
                    p {
                        @apply text-sm font-medium;
                    }
                }
            }
        }
        .gallery {
            @apply p-5 max-md:w-full max-md:overflow-y-auto max-md:bg-white max-md:p-[2px];
            ul {
                @apply grid grid-cols-5 grid-rows-5 gap-2.5 max-md:grid-cols-3 max-md:gap-[2px] max-md:relative;
                li {
                    @apply max-md:relative max-md:col-auto max-md:row-auto;
                    img {
                        @apply size-full object-cover rounded-lg max-md:aspect-square max-md:w-full max-md:h-full max-md:rounded-none;
                    }
                    &:first-child {
                        @apply row-start-1 row-span-3 col-start-1 col-span-3 max-md:row-auto max-md:col-auto;
                    }
                    &:nth-child(2) {
                        @apply row-start-1 row-span-3 col-start-4 col-span-2 max-md:row-auto max-md:col-auto;
                    }
                    &:nth-child(3) {
                        @apply row-start-4 row-span-2 col-start-3 col-span-3 max-md:row-auto max-md:col-auto;
                    }
                    &:last-child {
                        @apply row-start-4 row-span-2 col-start-1 col-span-2 max-md:row-auto max-md:col-auto;
                    }
                }
            }
        }
    }

    #resume {
        @apply w-fit h-fit absolute top-16 left-7/12 bg-white/30 backdrop-blur-xl shadow-2xl drop-shadow-2xl rounded-xl overflow-hidden max-md:inset-0 max-md:w-full max-md:h-full max-md:rounded-none max-md:bg-white;
        #window-header {
            h2 {
                @apply font-bold text-sm text-center flex-1;
            }
        }
    }

    #finder {
        @apply backdrop-blur-xl absolute w-3xl left-40 top-20 shadow-2xl drop-shadow-2xl overflow-hidden rounded-xl max-md:inset-0 max-md:w-full max-md:h-full max-md:rounded-none max-md:bg-white;
        .sidebar {
            @apply w-48 bg-gray-50 border-r border-gray-200 flex flex-col p-5 space-y-3 max-md:hidden;
            h3 {
                @apply text-xs font-medium text-gray-400 mb-1;
            }
            ul {
                @apply space-y-1;
                .active {
                    @apply bg-blue-100 text-blue-700;
                }
                .not-active {
                    @apply text-gray-700 hover:bg-gray-200;
                }
                li {
                    @apply flex items-center gap-2 px-3 py-2 rounded-md cursor-pointer transition-colors;
                }
            }
        }
        .content {
            @apply flex-1 p-8 max-w-2xl relative max-md:block max-md:w-full max-md:p-4 max-md:bg-[#f2f2f7];
            ul {
                @apply max-md:flex max-md:flex-col max-md:overflow-hidden;
            }
            li {
                @apply absolute flex items-center flex-col gap-3 max-md:relative max-md:top-0 max-md:left-0 max-md:flex-row max-md:justify-start max-md:p-3 max-md:gap-4;
                &:last-child {
                    @apply max-md:border-b-0;
                }
                img {
                    @apply object-contain object-center size-16 relative group-hover:scale-105 max-md:w-10 max-md:h-10 max-md:rounded-lg;
                }
                p {
                    @apply text-sm text-center font-medium w-40 max-md:text-left max-md:w-full max-md:text-[17px] max-md:text-black max-md:font-normal;
                }
            }
            h3 {
                @apply max-md:hidden;
            }
        }
    }

    #txtfile {
        @apply absolute bg-white/30 backdrop-blur-xl shadow-2xl drop-shadow-2xl rounded-xl overflow-hidden top-[15%] left-[60%] w-[500px] h-[600px] transition-none max-md:inset-0 max-md:w-full max-md:h-full max-md:rounded-none max-md:bg-white;
    }

    #imgfile {
        @apply absolute bg-white/30 backdrop-blur-xl shadow-2xl drop-shadow-2xl rounded-xl overflow-hidden top-[20%] left-[20%] w-[650px] h-[500px] transition-none max-md:inset-0 max-md:w-full max-md:h-full max-md:rounded-none max-md:bg-white;
    }

    #home {
        @apply relative z-0 w-full h-full;
        .desktop-projects {
            li {
                @apply absolute z-0 select-none flex items-center flex-col cursor-pointer;
                img {
                    @apply group-hover:bg-gray-950/10 p-1 rounded-md;
                }
                p {
                    @apply text-sm text-white text-center px-1 rounded-md group-hover:bg-blue-500 transition-colors max-w-40;
                }
            }
        }
    }

    .ios-home-indicator {
        @apply fixed bottom-2 left-1/2 -translate-x-1/2 w-[130px] h-1.5 bg-white/60 rounded-full z-[100] pointer-events-none max-md:block hidden;
    }
}
