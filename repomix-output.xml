                  <ul className="space-y-2">
                    {techStack.map(({ category, items }) => (
                      <li key={category} className="flex items-start">
                        <Check className="text-[#00A154] mr-2 mt-1" size={14} />
                        <h3 className="w-32 font-bold text-[#00A154] text-xs">
