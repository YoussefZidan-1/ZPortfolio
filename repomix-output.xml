                      }
                    >
                      {k}
                      {node.content[k].type === "dir" ? "/" : ""}
                    </span>
                  ))}
                </div>
              );
            }
          }
          break;
        }

        case "cd": {
          const target = arg || "~";
          const { node, path } = resolvePath(target);
          if (!node) {
            response = (
              <span className="text-red-400">
                cd: no such file or directory: {arg}
              </span>
            );
          } else if (node.type !== "dir") {
            response = (
              <span className="text-red-400">cd: not a directory: {arg}</span>
            );
          } else {
            setCwd(path);
            return;
          }
          break;
        }

        case "pwd":
          response = (
            <span className="text-white">
              ~{cwd.length ? "/" + cwd.join("/") : ""}
            </span>
          );
          break;

        case "cat": {
          if (!arg) {
            response = (
              <span className="text-red-400">cat: missing file operand</span>
            );
            break;
          }
          const { node } = resolvePath(arg);
          if (!node) {
            response = (
              <span className="text-red-400">
                cat: {arg}: No such file or directory
              </span>
            );
          } else if (node.type === "dir") {
            response = (
              <span className="text-red-400">cat: {arg}: Is a directory</span>
            );
          } else {
            if (arg === "techstack.md" || arg.endsWith("/techstack.md")) {
              response = (
                <div className="mt-2 border-l-2 border-indigo-500 pl-4 py-2 bg-white/5">
                  <div className="label mb-2 flex opacity-50 text-xs uppercase tracking-widest">
                    <p className="w-32 text-white font-bold">Category</p>
                    <p className="text-white font-bold">Technologies</p>
