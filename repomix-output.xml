                  {node.content}
                </span>
              );
            }
          }
          break;
        }

        case "xdg-open": {
          if (!arg) {
            response = (
              <span className="text-red-400">
                xdg-open: missing file operand
              </span>
            );
            break;
          }
          if (SYSTEM_APPS[arg]) {
            openWindow(SYSTEM_APPS[arg].id);
            response = (
              <span className="text-blue-400">
                Launching {SYSTEM_APPS[arg].name}...
              </span>
            );
            break;
          }

          const { node, path } = resolvePath(arg);
          if (!node) {
            response = (
              <span className="text-red-400">
                xdg-open: {arg}: No such file or directory
              </span>
            );
          } else if (node.type === "dir") {
            response = (
              <span className="text-red-400">
