                            &::before {
                                content: '';
                                @apply absolute inset-0 bg-blue-500/15 rounded-2xl opacity-0 scale-75 transition-all duration-300 ease-[cubic-bezier(0.175,0.885,0.32,1.275)] z-[-1] max-md:hidden;
